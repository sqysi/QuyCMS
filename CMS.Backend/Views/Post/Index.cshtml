@model IEnumerable<CMS.Data.Entities.Post>
@{
    Layout = "_LayoutAdmin";
}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold mb-0"><i class="bi bi-file-earmark-text"></i> QUẢN LÝ BÀI VIẾT</h2>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-lg"></i> Thêm bài viết mới
        </a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 col-lg-3 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <img src="@item.ImageUrl" class="card-img-top" alt="Thumbnail" style="height: 200px; object-fit: cover;">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-primary fw-bold">@item.Title</h5>
                        <p class="card-text text-muted small mb-2"><i class="bi bi-calendar-event"></i> Ngày đăng: @item.CreatedDate.ToString("dd/MM/yyyy")</p>
                        <p class="card-text text-truncate flex-grow-1">@item.Content</p>

                        <div class="mt-3 pt-3 border-top d-flex justify-content-between">
                            <a href="/Post/Details/@item.Id" class="btn btn-outline-info btn-sm" title="Xem chi tiết">
                                <i class="bi bi-eye"></i>
                            </a>
                            <div>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm" title="Sửa">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm"
                                   onclick="return confirm('Bạn có chắc chắn muốn xóa bài viết này không?')" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>