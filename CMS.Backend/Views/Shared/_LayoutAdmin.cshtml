<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root {
            --sidebar-bg: #212529;
            --accent-color: #0d6efd;
        }

        body {
            background-color: #f8f9fa;
        }

        .sidebar {
            min-height: 100vh;
            background-color: var(--sidebar-bg);
            transition: 0.3s;
        }

            .sidebar a {
                color: #adb5bd;
                text-decoration: none;
                display: block;
                padding: 12px 20px;
                border-left: 4px solid transparent;
                font-size: 0.95rem;
            }

                .sidebar a:hover {
                    background-color: #343a40;
                    color: white;
                    border-left: 4px solid var(--accent-color);
                }

                .sidebar a.active {
                    background-color: #343a40;
                    color: white;
                    border-left: 4px solid var(--accent-color);
                    font-weight: bold;
                }

        .menu-header {
            color: #6c757d;
            font-size: 0.75rem;
            text-transform: uppercase;
            padding: 20px 20px 10px;
            letter-spacing: 1px;
        }

        .main-content {
            transition: 0.3s;
        }

        .navbar-top {
            background: white;
            border-bottom: 1px solid #dee2e6;
        }
    </style>
</head>
<body>

    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-3 col-lg-2 sidebar p-0 d-md-block">
                <div class="p-3 text-center border-bottom border-secondary">
                    <h5 class="text-white mb-0"><i class="bi bi-speedometer2"></i> QuyCMS Admin</h5>
                </div>

                <div class="menu-header">Quản trị nội dung</div>
                <a asp-controller="Home" asp-action="Index"><i class="bi bi-house"></i> Dashboard</a>
                <a asp-controller="Post" asp-action="Index"><i class="bi bi-file-earmark-post"></i> Bài viết</a>
                <a asp-controller="Category" asp-action="Index"><i class="bi bi-folder2"></i> Danh mục tin</a>

                <div class="menu-header">Quản trị bán hàng</div>
                <a asp-controller="Product" asp-action="Index"><i class="bi bi-box-seam"></i> Sản phẩm</a>
                <a asp-controller="CategoryProduct" asp-action="Index"><i class="bi bi-grid"></i> Danh mục SP</a>
                <a asp-controller="Order" asp-action="Index"><i class="bi bi-cart4"></i> Đơn hàng</a>
                <a asp-controller="Customer" asp-action="Index"><i class="bi bi-people"></i> Khách hàng</a>

                <div class="menu-header">Hệ thống</div>
                <a asp-controller="User" asp-action="Index"><i class="bi bi-person-badge"></i> Thành viên</a>
            </nav>

            <main class="col-md-9 col-lg-10 p-0">
                <header class="navbar-top p-3 d-flex justify-content-between align-items-center shadow-sm">
                    <span class="text-muted fw-bold">Xin chào, @User.FindFirst("FullName")?.Value</span>
                    <a class="btn btn-outline-danger btn-sm" asp-controller="Account" asp-action="Logout">
                        <i class="bi bi-box-arrow-right"></i> Đăng xuất
                    </a>
                </header>

                <div class="p-4">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Tự động active menu dựa trên URL
        $(document).ready(function () {
            var path = window.location.pathname;
            $('.sidebar a').each(function () {
                var href = $(this).attr('href');
                if (path.includes(href) && href !== '/') {
                    $(this).addClass('active');
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>