@model IEnumerable<CMS.Data.Entities.User>
@{
    Layout = "_LayoutAdmin";
}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-dark">QUẢN LÝ THÀNH VIÊN</h2>
        <a asp-action="Create" class="btn btn-success btn-sm">
            <i class="bi bi-plus-circle"></i> + Thêm thành viên mới
        </a>
    </div>

    <table class="table table-hover shadow-sm border">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Tên Đăng Nhập</th>
                <th>Họ Và Tên</th>
                <th>Quyền Hạn</th>
                <th style="width:150px">Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Id</td>
                    <td><strong>@user.Username</strong></td>
                    <td>@user.FullName</td>
                    <td>
                        @if (user.Role == "Administrator")
                        {
                            <span class="badge bg-danger">@user.Role</span>
                        }
                        else
                        {
                            <span class="badge bg-info text-dark">@user.Role</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-warning">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger"
                           onclick="return confirm('Bạn có chắc chắn muốn xóa thành viên này?')">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>