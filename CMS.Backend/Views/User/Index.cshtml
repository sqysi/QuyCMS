@model IEnumerable<CMS.Data.Entities.User>
@{
    Layout = "_LayoutAdmin";
}
<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
            <h4 class="mb-0 text-primary fw-bold"><i class="bi bi-people-fill"></i> QUẢN LÝ THÀNH VIÊN</h4>
            <a asp-action="Create" class="btn btn-success btn-sm shadow-sm">
                <i class="bi bi-plus-lg"></i> Thêm thành viên
            </a>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Tên Đăng Nhập</th>
                            <th>Họ Và Tên</th>
                            <th>Quyền Hạn</th>
                            <th class="text-end pe-4" style="width: 200px;">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-4">#@user.Id</td>
                                <td><strong class="text-dark">@user.Username</strong></td>
                                <td>@user.FullName</td>
                                <td>
                                    @if (user.Role == "Administrator")
                                    {
                                        <span class="badge bg-danger rounded-pill px-3 py-2"><i class="bi bi-shield-lock"></i> @user.Role</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info text-dark rounded-pill px-3 py-2"><i class="bi bi-person"></i> @user.Role</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-pencil-square"></i> Sửa
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('Bạn có chắc chắn muốn xóa thành viên này?')">
                                        <i class="bi bi-trash"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>