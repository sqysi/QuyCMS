@model CMS.Data.Entities.Product
@{
    Layout = "_LayoutAdmin";
}
<div class="container mt-4">
    <h2 class="text-primary">THÊM SẢN PHẨM MỚI</h2>
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div class="row">
            <div class="col-md-8">
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên sản phẩm:</label>
                    <input asp-for="Name" class="form-control" required />
                </div>
                <input type="hidden" asp-for="CategoryProductId" />
                <div class="mb-3">
                    <label class="form-label fw-bold">Mô tả:</label>
                    <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Hình ảnh:</label>
                    <input type="file" name="imageFile" class="form-control" accept="image/*" />
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-3">
                    <label class="form-label fw-bold">Giá:</label>
                    <input asp-for="Price" type="number" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Số lượng:</label>
                    <input asp-for="StockQuantity" type="number" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Category ID:</label>
                    <input asp-for="CategoryProductId" type="number" class="form-control" required />
                </div>
            </div>
        </div>
        <button type="submit" class="btn btn-success">Lưu sản phẩm</button>
        <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
    </form>
</div>